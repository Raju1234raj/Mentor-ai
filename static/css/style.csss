*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #0d0f14;
  --bg2: #13161e;
  --bg3: #1a1e28;
  --bg4: #20253200;
  --surface: #1e2330;
  --surface2: #252b3b;
  --border: #2e354a;
  --accent: #5b8cff;
  --accent2: #8b6cff;
  --accent-dim: rgba(91,140,255,0.12);
  --warn: #ff8a5b;
  --warn-dim: rgba(255,138,91,0.12);
  --danger: #ff5b7c;
  --danger-dim: rgba(255,91,124,0.12);
  --safe: #4ee19c;
  --safe-dim: rgba(78,225,156,0.12);
  --text: #f0f2f8;
  --text2: #8b91a8;
  --text3: #555d78;
  --danger: #ff5e5e;
  --success: #4ede9a;
  --warning: #ffc84a;
  --font-display: 'Syne', sans-serif;
  --font-body: 'DM Sans', sans-serif;
  --radius: 12px;
  --radius-lg: 18px;
  --sidebar-w: 200px;
  --transition: 0.2s ease;
}
html { font-size: 16px; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  display: flex;
  min-height: 100vh;
  overflow-x: hidden;
}
.sidebar {
  width: var(--sidebar-w);
  min-height: 100vh;
  background: var(--bg2);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0; left: 0;
  z-index: 100;
  transition: transform var(--transition);
}
.sidebar-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 16px 16px 14px;
  border-bottom: 1px solid var(--border);
}
.logo-mark {
  width: 36px; height: 36px;
  background: var(--accent);
  color: #0d0f14;
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 14px;
  border-radius: 8px;
  display: grid;
  place-items: center;
  letter-spacing: -0.5px;
}
.logo-text {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 17px;
  color: var(--text);
}
.sidebar-nav {
  flex: 1;
  padding: 10px 8px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 12px;
  border-radius: var(--radius);
  border: none;
  background: transparent;
  color: var(--text2);
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 400;
  cursor: pointer;
  transition: all var(--transition);
  text-align: left;
  width: 100%;
}
.nav-item:hover { background: var(--surface); color: var(--text); }
.nav-item.active {
  background: var(--accent-dim);
  color: var(--accent);
  font-weight: 500;
}
.nav-icon { font-size: 13px; opacity: 0.7; }
.focus-timer-widget {
  margin: 16px;
  padding: 16px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  text-align: center;
}
.focus-timer-widget h4 {
  font-size: 12px;
  color: var(--text2);
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.time-display {
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 800;
  color: var(--accent);
  margin-bottom: 12px;
}
.sidebar-footer {
  padding: 16px 20px;
  border-top: 1px solid var(--border);
}
.api-status {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 12px;
  color: var(--text3);
}
.status-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--success);
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0%,100% { opacity: 1; }
  50% { opacity: 0.4; }
}
.main {
  flex: 1;
  margin-left: var(--sidebar-w);
  width: calc(100% - var(--sidebar-w));
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
.mobile-header {
  display: none;
  padding: 14px 20px;
  border-bottom: 1px solid var(--border);
  align-items: center;
  gap: 14px;
  background: var(--bg2);
  position: sticky; top: 0; z-index: 50;
}
.hamburger {
  background: none;
  border: none;
  color: var(--text);
  font-size: 20px;
  cursor: pointer;
}
.mobile-logo {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 16px;
}
.page { display: none; flex-direction: column; padding: 28px 36px; flex: 1; width: 100%; max-width: 100%; }
.page.active { display: flex; }
.page-header { margin-bottom: 18px; }
.page-header h1 {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 26px;
  letter-spacing: -0.5px;
  color: var(--text);
  margin-bottom: 8px;
}
.page-header p { color: var(--text2); font-size: 15px; font-weight: 300; }
.chat-container {
  display: flex;
  flex-direction: column;
  flex: 1;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  height: calc(100vh - 160px);
  min-height: 400px;
}
.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 28px 28px 16px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}
.chat-welcome {
  text-align: center;
  padding: 40px 20px;
  margin: auto;
  max-width: 460px;
}
.welcome-icon { font-size: 36px; color: var(--accent); margin-bottom: 16px; }
.chat-welcome h2 {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 22px;
  margin-bottom: 10px;
}
.chat-welcome p { color: var(--text2); font-size: 14px; margin-bottom: 24px; line-height: 1.7; }
.suggestion-chips { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }
.chip {
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text2);
  font-family: var(--font-body);
  font-size: 13px;
  padding: 7px 14px;
  border-radius: 100px;
  cursor: pointer;
  transition: all var(--transition);
}
.chip:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
.msg {
  display: flex;
  gap: 12px;
  animation: msgIn 0.25s ease;
}
@keyframes msgIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
.msg-avatar {
  width: 32px; height: 32px;
  border-radius: 8px;
  flex-shrink: 0;
  font-size: 13px;
  font-weight: 700;
  display: grid;
  place-items: center;
  font-family: var(--font-display);
}
.msg.user .msg-avatar { background: var(--surface2); color: var(--text2); margin-left: auto; }
.msg.ai .msg-avatar { background: var(--accent); color: #0d0f14; }
.msg.user { flex-direction: row-reverse; }
.msg-bubble {
  max-width: 72%;
  padding: 12px 16px;
  border-radius: 14px;
  font-size: 13px;
  line-height: 1.7;
}
.msg.user .msg-bubble { background: var(--surface2); color: var(--text); border-bottom-right-radius: 4px; }
.msg.ai .msg-bubble { background: var(--surface); color: var(--text); border-bottom-left-radius: 4px; }
.msg.ai .msg-bubble h3 {
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 600;
  color: var(--accent);
  margin-bottom: 6px;
  margin-top: 12px;
}
.msg.ai .msg-bubble h3:first-child { margin-top: 0; }
.msg.ai .msg-bubble p { margin-bottom: 8px; }
.msg.ai .msg-bubble p:last-child { margin-bottom: 0; }
.msg.ai .msg-bubble ul { padding-left: 18px; margin-bottom: 8px; }
.msg.ai .msg-bubble li { margin-bottom: 4px; }
.msg.ai .msg-bubble strong { color: var(--accent); font-weight: 500; }
.msg.ai .msg-bubble code {
  background: var(--bg);
  color: var(--accent);
  padding: 1px 6px;
  border-radius: 4px;
  font-size: 13px;
}
.typing-indicator { display: flex; align-items: center; gap: 5px; padding: 4px 0; }
.typing-indicator span {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--text3);
  animation: typing 1.2s infinite;
}
.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing { 0%,60%,100% { transform: none; opacity: 0.4; } 30% { transform: translateY(-5px); opacity: 1; } }
.chat-input-wrap {
  display: flex;
  align-items: flex-end;
  gap: 10px;
  padding: 16px 20px;
  border-top: 1px solid var(--border);
  background: var(--bg2);
}
.chat-input {
  flex: 1;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  font-family: var(--font-body);
  font-size: 14px;
  padding: 12px 16px;
  resize: none;
  outline: none;
  max-height: 120px;
  line-height: 1.5;
  transition: border-color var(--transition);
}
.chat-input:focus { border-color: var(--accent); }
.chat-input::placeholder { color: var(--text3); }
.send-btn {
  width: 42px; height: 42px;
  border-radius: 10px;
  background: var(--accent);
  color: #0d0f14;
  border: none;
  cursor: pointer;
  display: grid;
  place-items: center;
  flex-shrink: 0;
  transition: all var(--transition);
}
.send-btn:hover { background: var(--accent2); transform: scale(1.05); }
.send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }
.summarizer-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; flex: 1; }
.input-panel, .output-panel {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.panel-label {
  font-family: var(--font-display);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--text3);
}
.notes-input {
  flex: 1;
  min-height: 280px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  font-family: var(--font-body);
  font-size: 14px;
  line-height: 1.7;
  padding: 14px 16px;
  resize: none;
  outline: none;
  transition: border-color var(--transition);
}
.notes-input:focus { border-color: var(--accent); }
.notes-input::placeholder { color: var(--text3); }
.input-actions { display: flex; gap: 10px; justify-content: flex-end; }
.output-placeholder {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  color: var(--text3);
}
.placeholder-icon { font-size: 26px; opacity: 0.4; }
.output-placeholder p { font-size: 14px; }
.summary-content {
  flex: 1;
  overflow-y: auto;
  font-size: 13px;
  line-height: 1.8;
  color: var(--text);
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}
.summary-content h3 {
  font-family: var(--font-display);
  font-size: 14px;
  font-weight: 700;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin: 16px 0 8px;
}
.summary-content h3:first-child { margin-top: 0; }
.summary-content p { margin-bottom: 10px; }
.summary-content ul { padding-left: 18px; margin-bottom: 10px; }
.summary-content li { margin-bottom: 5px; }
.summary-content strong { color: var(--accent); font-weight: 500; }
.btn-primary {
  background: var(--accent);
  color: #0d0f14;
  border: none;
  border-radius: var(--radius);
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 500;
  padding: 11px 22px;
  cursor: pointer;
  transition: all var(--transition);
}
.btn-primary:hover { background: var(--accent2); transform: translateY(-1px); }
.btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
.btn-primary.full-width { width: 100%; padding: 13px; font-size: 15px; }
.btn-secondary {
  background: var(--surface);
  color: var(--text2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  font-family: var(--font-body);
  font-size: 14px;
  padding: 11px 18px;
  cursor: pointer;
  transition: all var(--transition);
}
.btn-secondary:hover { background: var(--surface2); color: var(--text); }
.quiz-form {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 32px;
  max-width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.form-group { display: flex; flex-direction: column; gap: 8px; }
.form-group label { font-size: 13px; font-weight: 500; color: var(--text2); }
.form-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
.form-select {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  font-family: var(--font-body);
  font-size: 14px;
  padding: 10px 14px;
  outline: none;
  cursor: pointer;
  transition: border-color var(--transition);
}
.form-select:focus { border-color: var(--accent); }
.quiz-progress {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 24px;
  font-size: 13px;
  color: var(--text2);
}
.exam-timer-display {
  background: var(--surface2);
  color: var(--danger);
  padding: 4px 12px;
  border-radius: 100px;
  font-weight: 700;
  font-family: var(--font-display);
}
.progress-bar { flex: 1; height: 4px; background: var(--surface2); border-radius: 99px; overflow: hidden; }
.progress-fill { height: 100%; background: var(--accent); border-radius: 99px; transition: width 0.4s ease; }
.question-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 32px;
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.question-text { font-size: 17px; font-weight: 400; line-height: 1.6; color: var(--text); }
.options-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.option-btn {
  background: var(--surface);
  border: 1.5px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  font-family: var(--font-body);
  font-size: 13px;
  padding: 14px 18px;
  cursor: pointer;
  text-align: left;
  transition: all var(--transition);
  display: flex;
  gap: 12px;
  align-items: flex-start;
}
.option-btn:hover:not(:disabled) { border-color: var(--accent); background: var(--accent-dim); }
.option-btn.correct { border-color: var(--success); background: rgba(78,222,154,0.1); color: var(--success); }
.option-btn.wrong { border-color: var(--danger); background: rgba(255,94,94,0.1); color: var(--danger); }
.option-btn:disabled { cursor: default; }
.option-letter {
  width: 24px; height: 24px;
  border-radius: 6px;
  background: var(--surface2);
  color: var(--text2);
  font-size: 12px;
  font-weight: 700;
  display: grid;
  place-items: center;
  flex-shrink: 0;
  margin-top: 1px;
}
.question-feedback {
  padding: 14px 16px;
  border-radius: var(--radius);
  font-size: 14px;
  line-height: 1.6;
}
.question-feedback.correct { background: rgba(78,222,154,0.1); border: 1px solid rgba(78,222,154,0.3); color: var(--success); }
.question-feedback.wrong { background: rgba(255,94,94,0.1); border: 1px solid rgba(255,94,94,0.3); color: #ff8e8e; }
.results-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 48px 40px;
  max-width: 100%;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.results-icon { font-size: 48px; color: var(--accent); }
.results-card h2 { font-family: var(--font-display); font-size: 26px; font-weight: 800; }
.results-card p { color: var(--text2); font-size: 15px; }
.results-stats {
  display: flex;
  gap: 20px;
  margin: 8px 0;
}
.stat-box {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 24px;
  text-align: center;
}
.stat-val { font-family: var(--font-display); font-size: 28px; font-weight: 800; color: var(--accent); }
.stat-lbl { font-size: 12px; color: var(--text3); margin-top: 4px; }
.flashcard-controls {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28px;
  font-size: 14px;
  color: var(--text2);
}
.flashcard-stage {
  display: flex;
  justify-content: center;
  margin-bottom: 28px;
  perspective: 1000px;
}
.flashcard {
  width: 100%;
  max-width: 800px;
  height: 400px;
  cursor: pointer;
  position: relative;
}
.flashcard-inner {
  width: 100%; height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.55s cubic-bezier(0.4, 0.2, 0.2, 1);
}
.flashcard-inner.flipped { transform: rotateY(180deg); }
.flashcard-front, .flashcard-back {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 36px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  gap: 12px;
}
.flashcard-back { transform: rotateY(180deg); border-color: var(--accent); }
.card-label {
  font-family: var(--font-display);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 2px;
  color: var(--text3);
  position: absolute;
  top: 18px; left: 24px;
}
.flashcard-back .card-label { color: var(--accent); opacity: 0.7; }
.flashcard-front p { font-size: 19px; font-weight: 500; line-height: 1.5; color: var(--text); }
.flashcard-back p { font-size: 15px; line-height: 1.8; color: var(--text); }
.flip-hint {
  font-size: 12px;
  color: var(--text3);
  position: absolute;
  bottom: 18px;
}
.flashcard-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
}
.nav-btn {
  width: 40px; height: 40px;
  border-radius: 10px;
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text);
  font-size: 18px;
  cursor: pointer;
  display: grid;
  place-items: center;
  transition: all var(--transition);
}
.nav-btn:hover { border-color: var(--accent); color: var(--accent); }
.card-dots { display: flex; gap: 6px; align-items: center; }
.dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--surface2);
  transition: all var(--transition);
}
.dot.active { background: var(--accent); width: 18px; border-radius: 99px; }
.loading-overlay {
  position: fixed; inset: 0;
  background: rgba(13,15,20,0.7);
  backdrop-filter: blur(4px);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.loader-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 36px 48px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}
.loader-dots { display: flex; gap: 8px; }
.loader-dots span {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--accent);
  animation: bounce 1.2s infinite;
}
.loader-dots span:nth-child(2) { animation-delay: 0.2s; }
.loader-dots span:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce { 0%,60%,100% { transform: none; opacity: 0.4; } 30% { transform: translateY(-10px); opacity: 1; } }
.loader-card p { color: var(--text2); font-size: 14px; }
.hidden { display: none !important; }
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }
@media (max-width: 768px) {
  .sidebar { transform: translateX(-100%); }
  .sidebar.open { transform: none; }
  .main { margin-left: 0; }
  .mobile-header { display: flex; }
  .page { padding: 24px 20px; }
  .summarizer-layout { grid-template-columns: 1fr; }
  .page-header h1 { font-size: 24px; }
  .flashcard { height: 220px; }
  .flashcard-front p { font-size: 16px; }
  .quiz-form { padding: 20px; }
  .form-row { grid-template-columns: 1fr; }
  .options-grid { grid-template-columns: 1fr; }
}
.source-tabs {
  display: flex;
  gap: 6px;
  margin-bottom: 20px;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 5px;
  width: fit-content;
}
.source-tab {
  padding: 8px 18px;
  border-radius: 8px;
  border: none;
  background: transparent;
  color: var(--text2);
  font-family: var(--font-body);
  font-size: 13.5px;
  font-weight: 400;
  cursor: pointer;
  transition: all var(--transition);
  display: flex;
  align-items: center;
  gap: 7px;
}
.source-tab:hover { color: var(--text); background: var(--surface); }
.source-tab.active { background: var(--surface2); color: var(--accent); font-weight: 500; }
.source-pane { display: none; flex-direction: column; gap: 12px; flex: 1; }
.source-pane.active { display: flex; }
.dropzone {
  border: 2px dashed var(--border);
  border-radius: var(--radius-lg);
  padding: 40px 24px;
  text-align: center;
  cursor: pointer;
  transition: all var(--transition);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-height: 200px;
  justify-content: center;
}
.dropzone:hover, .dropzone.drag-over { border-color: var(--accent); background: var(--accent-dim); }
.dropzone-icon { font-size: 26px; color: var(--text3); margin-bottom: 4px; }
.dropzone-title { font-size: 15px; font-weight: 500; color: var(--text); }
.dropzone-sub { font-size: 12px; color: var(--text3); }
.file-info {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px 16px;
}
.file-icon { font-size: 20px; color: var(--accent); flex-shrink: 0; }
.file-meta { flex: 1; display: flex; flex-direction: column; gap: 2px; overflow: hidden; }
.file-name { font-size: 13px; font-weight: 500; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.file-size { font-size: 11px; color: var(--text3); }
.file-remove {
  background: none; border: none; color: var(--text3);
  cursor: pointer; font-size: 14px; padding: 4px;
  border-radius: 4px; flex-shrink: 0;
  transition: color var(--transition);
}
.file-remove:hover { color: var(--danger); }
.url-input {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  font-family: var(--font-body);
  font-size: 14px;
  padding: 13px 16px;
  outline: none;
  transition: border-color var(--transition);
  width: 100%;
}
.url-input:focus { border-color: var(--accent); }
.url-input::placeholder { color: var(--text3); }
.url-hint { font-size: 12px; color: var(--text3); line-height: 1.6; }
.video-preview { margin-top: 8px; }
.extracted-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--accent-dim);
  border: 1px solid rgba(200,240,78,0.25);
  color: var(--accent);
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 100px;
  margin-bottom: 10px;
}
/* ===== SOURCE TABS ===== */
.source-tabs{display:flex;gap:6px;margin-bottom:20px;background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:5px;width:fit-content;}
.source-tab{padding:8px 18px;border-radius:8px;border:none;background:transparent;color:var(--text2);font-family:var(--font-body);font-size:13.5px;cursor:pointer;transition:all var(--transition);display:flex;align-items:center;gap:7px;}
.source-tab:hover{color:var(--text);background:var(--surface);}
.source-tab.active{background:var(--surface2);color:var(--accent);font-weight:500;}
.source-pane{display:none;flex-direction:column;gap:12px;flex:1;}
.source-pane.active{display:flex;}

/* ===== DROPZONE / FILE ===== */
.dropzone{border:2px dashed var(--border);border-radius:var(--radius-lg);padding:40px 24px;text-align:center;cursor:pointer;transition:all var(--transition);display:flex;flex-direction:column;align-items:center;gap:8px;flex:1;min-height:180px;justify-content:center;}
.dropzone:hover,.dropzone.drag-over{border-color:var(--accent);background:var(--accent-dim);}
.dropzone-icon{font-size:32px;color:var(--text3);}
.dropzone-title{font-size:15px;font-weight:500;color:var(--text);}
.dropzone-sub{font-size:12px;color:var(--text3);}
.file-info{display:flex;align-items:center;gap:12px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;}
.file-icon{font-size:20px;color:var(--accent);flex-shrink:0;}
.file-meta{flex:1;display:flex;flex-direction:column;gap:2px;overflow:hidden;}
.file-name{font-size:13px;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.file-size{font-size:11px;color:var(--text3);}
.file-remove{background:none;border:none;color:var(--text3);cursor:pointer;font-size:14px;padding:4px;border-radius:4px;flex-shrink:0;transition:color var(--transition);}
.file-remove:hover{color:var(--danger);}
.url-input{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);font-family:var(--font-body);font-size:14px;padding:13px 16px;outline:none;transition:border-color var(--transition);width:100%;}
.url-input:focus{border-color:var(--accent);}
.url-input::placeholder{color:var(--text3);}
.url-hint{font-size:12px;color:var(--text3);line-height:1.6;}
.video-preview{margin-top:8px;}
.extracted-badge{display:inline-flex;align-items:center;gap:6px;background:var(--accent-dim);border:1px solid rgba(200,240,78,0.25);color:var(--accent);font-size:12px;padding:4px 10px;border-radius:100px;}

/* ===== NAV DIVIDER ===== */
.nav-divider{font-size:10px;font-weight:700;letter-spacing:2px;color:var(--text3);padding:12px 14px 4px;text-transform:uppercase;}

/* ===== FULLSCREEN / TOP ACTIONS ===== */
.fullscreen-btn{background:none;border:none;color:var(--text3);font-size:16px;cursor:pointer;padding:4px 8px;border-radius:6px;transition:all var(--transition);}
.fullscreen-btn:hover{color:var(--accent);}
.btn-icon{background:none;border:none;color:var(--text2);font-size:18px;cursor:pointer;padding:4px;}
.top-actions{position:absolute;top:16px;right:20px;z-index:10;}

/* ===== FEYNMAN CHECKER ===== */
.feynman-layout{display:grid;grid-template-columns:1fr 1fr;gap:20px;flex:1;}
.feynman-section{padding:14px 16px;border-radius:var(--radius);margin-bottom:4px;}
.feynman-section-title{font-size:12px;font-weight:700;letter-spacing:0.5px;text-transform:uppercase;margin-bottom:8px;}
.feynman-section ul{padding-left:18px;}
.feynman-section li{margin-bottom:5px;font-size:13.5px;line-height:1.6;}
.feynman-section p{font-size:13.5px;line-height:1.6;}
.success-section{background:rgba(78,222,154,0.08);border:1px solid rgba(78,222,154,0.2);}
.success-section .feynman-section-title{color:var(--success);}
.warning-section{background:rgba(255,200,74,0.08);border:1px solid rgba(255,200,74,0.2);}
.warning-section .feynman-section-title{color:var(--warning);}
.danger-section{background:rgba(255,94,94,0.08);border:1px solid rgba(255,94,94,0.2);}
.danger-section .feynman-section-title{color:var(--danger);}
.info-section{background:var(--surface);border:1px solid var(--border);}
.info-section .feynman-section-title{color:var(--accent);}

/* ===== EXAM PANIC ===== */
.panic-layout{display:flex;flex-direction:column;gap:24px;}
.panic-btn{background:linear-gradient(135deg,#ff5e5e,#ff8c42)!important;color:#fff!important;}
.panic-btn:hover{opacity:0.9;transform:translateY(-1px);}
.panic-result{display:flex;flex-direction:column;gap:16px;}
.panic-header{display:flex;align-items:center;gap:12px;}
.panic-badge{background:rgba(255,94,94,0.15);border:1px solid rgba(255,94,94,0.3);color:#ff8e8e;font-size:13px;font-weight:600;padding:6px 14px;border-radius:100px;}
.panic-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.panic-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:20px;}
.panic-card h3{font-family:var(--font-display);font-size:14px;font-weight:700;color:var(--text);margin-bottom:12px;}
.panic-card ul{padding-left:18px;}
.panic-card li{font-size:13px;color:var(--text2);margin-bottom:6px;line-height:1.6;}
.time-slots{display:flex;flex-direction:column;gap:8px;}
.time-slot{display:grid;grid-template-columns:80px 1fr 12px;gap:8px;align-items:start;font-size:13px;}
.slot-time{color:var(--accent);font-weight:600;font-size:12px;}
.slot-task{color:var(--text2);line-height:1.5;}
.panic-tip{background:linear-gradient(135deg,rgba(255,94,94,0.1),rgba(255,140,66,0.1));border:1px solid rgba(255,94,94,0.2);border-radius:var(--radius-lg);padding:16px 20px;font-size:14px;color:var(--text);line-height:1.7;}

/* ===== CONCEPT MAP ===== */
.concept-map-wrap{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:16px;min-height:200px;display:flex;flex-direction:column;}

/* ===== ELI5 SLIDER ===== */
.eli5-layout{display:grid;grid-template-columns:1fr 1fr;gap:20px;flex:1;}
.level-slider-wrap{display:flex;flex-direction:column;gap:10px;}
.level-slider{-webkit-appearance:none;width:100%;height:6px;border-radius:99px;background:var(--surface2);outline:none;cursor:pointer;}
.level-slider::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;background:var(--accent);cursor:pointer;border:2px solid var(--bg);}
.level-labels{display:flex;justify-content:space-between;font-size:11px;color:var(--text3);}
.level-badge{background:var(--accent-dim);border:1px solid rgba(200,240,78,0.25);color:var(--accent);font-size:13px;font-weight:600;padding:6px 14px;border-radius:100px;align-self:flex-start;margin-top:4px;}
.chip-active{border-color:var(--accent)!important;color:var(--accent)!important;background:var(--accent-dim)!important;}

/* ===== EXAM TIMER ===== */
.exam-timer-display{font-size:14px;font-weight:600;color:var(--warning);font-family:var(--font-display);}

/* ===== VOICE QUIZ ===== */
.voice-card{display:flex;flex-direction:column;gap:16px;}
.voice-controls{display:flex;flex-direction:column;align-items:center;gap:16px;padding:20px 0;}
.record-btn{width:100px;height:100px;border-radius:50%;border:3px solid var(--accent);background:var(--accent-dim);color:var(--accent);cursor:pointer;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;transition:all var(--transition);font-family:var(--font-body);}
.record-btn:hover{background:rgba(200,240,78,0.2);transform:scale(1.05);}
.record-btn.recording{border-color:var(--danger);background:rgba(255,94,94,0.15);color:var(--danger);animation:recordPulse 1s infinite;}
@keyframes recordPulse{0%,100%{box-shadow:0 0 0 0 rgba(255,94,94,0.4);}50%{box-shadow:0 0 0 12px rgba(255,94,94,0);}}
.record-icon{font-size:28px;}
#recordLabel{font-size:11px;text-align:center;}
.voice-transcript-wrap{width:100%;max-width:500px;}
.voice-transcript{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;min-height:60px;font-size:14px;line-height:1.7;color:var(--text3);}
.voice-grade{display:flex;align-items:center;gap:16px;padding:16px 20px;border-radius:var(--radius-lg);}
.voice-grade.correct{background:rgba(78,222,154,0.1);border:1px solid rgba(78,222,154,0.3);}
.voice-grade.wrong{background:rgba(255,94,94,0.1);border:1px solid rgba(255,94,94,0.3);}
.voice-grade-score{font-family:var(--font-display);font-size:36px;font-weight:800;}
.voice-grade-verdict{font-size:14px;line-height:1.6;}

/* ===== FOCUS TIMER WIDGET ===== */
.focus-timer-widget{margin:12px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px;display:flex;flex-direction:column;gap:8px;}
.focus-timer-widget h4{font-family:var(--font-display);font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--text3);}
.time-display{font-family:var(--font-display);font-size:28px;font-weight:800;color:var(--accent);text-align:center;letter-spacing:2px;}

/* ===== RESPONSIVE ADDITIONS ===== */
@media (max-width:768px){
  .sidebar{transform:translateX(-100%);}
  .sidebar.open{transform:none;}
  .main{margin-left:0;}
  .mobile-header{display:flex;}
  .page{padding:24px 20px;}
  .summarizer-layout,.feynman-layout,.eli5-layout{grid-template-columns:1fr;}
  .panic-grid{grid-template-columns:1fr;}
  .page-header h1{font-size:24px;}
  .flashcard{height:220px;}
}
/* ===== MENTOR DASHBOARD ===== */
.mentor-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:22px;}
.mentor-toolbar{display:flex;align-items:center;gap:14px;margin-bottom:20px;flex-wrap:wrap;}
.mentor-hint{font-size:13px;color:var(--text3);}
.mentor-roster{display:flex;flex-direction:column;gap:10px;}
.loading-spinner{width:28px;height:28px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite;margin:30px auto;}
@keyframes spin{to{transform:rotate(360deg);}}

.student-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;display:flex;align-items:center;gap:16px;transition:.15s;}
.student-card:hover{border-color:var(--accent);}
.student-avatar{width:42px;height:42px;border-radius:50%;background:var(--accent-dim);color:var(--accent);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:15px;flex-shrink:0;}
.student-info{flex:1;min-width:0;}
.student-name{font-weight:600;font-size:15px;}
.student-meta{font-size:12px;color:var(--text3);margin-top:2px;}
.risk-badge{font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;padding:5px 10px;border-radius:20px;white-space:nowrap;}
.risk-badge.at-risk{background:var(--danger-dim);color:var(--danger);}
.risk-badge.watch{background:var(--warn-dim);color:var(--warn);}
.risk-badge.safe{background:var(--safe-dim);color:var(--safe);}
.risk-meter{width:80px;height:6px;background:var(--bg3);border-radius:4px;overflow:hidden;flex-shrink:0;}
.risk-meter-fill{height:100%;border-radius:4px;}
.student-actions{flex-shrink:0;}
.btn-nudge{background:var(--accent-dim);color:var(--accent);border:none;padding:8px 14px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;transition:.15s;}
.btn-nudge:hover{background:var(--accent);color:#0d0f14;}
.btn-nudge:disabled{opacity:.5;cursor:default;}

.mentor-nudge-panel{margin-top:22px;background:var(--surface);border:1px solid var(--accent);border-radius:var(--radius);padding:20px;}
.mentor-nudge-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;}
.mentor-nudge-header h3{font-size:16px;}
.nudge-subject{font-weight:700;font-size:15px;margin-bottom:8px;color:var(--accent);}
.nudge-message{font-size:14px;line-height:1.7;color:var(--text2);margin-bottom:14px;}
.nudge-action{display:inline-block;background:var(--accent-dim);color:var(--accent);padding:8px 14px;border-radius:8px;font-size:13px;font-weight:600;}

@media (max-width:768px){
  .mentor-stats{grid-template-columns:repeat(2,1fr);}
  .student-card{flex-wrap:wrap;}
}

